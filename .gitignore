# Dependencies
node_modules/
package-lock.json

# Build output
dist/
build/
.angular/

# Data directories (user data should never be committed)
data/
data-test/
data/queues/
data/queues-test/
data/users/
data/users-test/

# Environment files (contain secrets)
.env
.env.local
.env.*.local
.env.production
.env.development

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Test coverage
coverage/
*.lcov
.nyc_output

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
.sublime-project
.sublime-workspace

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Docker volumes and data
docker-compose.override.yml
letsencrypt/
backups/*.tar.gz

# Temporary files
tmp/
temp/
*.tmp
*.bak

# TypeScript
*.tsbuildinfo

# Angular specific
.angular/
.angular/cache/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env.test

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional stylelint cache
.stylelintcache

# SvelteKit
.svelte-kit

